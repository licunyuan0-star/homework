#step 1:生成新的ssh密钥
#1、打开终端
#2、生成新的密钥对
#执行以下命令：
ssh-keygen -t ed25519 -C "my_email@example.com"
#step 2:将公钥添加到GitHub
#1、复制公钥，执行以下命令：
cat ~/.ssh/id_ed25519.pub
#2、登录 GitHub 并添加：
#在浏览器中登录 GitHub。
#点击右上角头像，然后选择 Settings 。
#在左侧边栏中，点击 SSH and GPG keys 。
#点击右上角的 New SSH key 按钮 。
#在 "Title" 输入框里，给密钥起一个容易识别的名字。
#在 "Key" 输入框里，粘贴你刚才复制的公钥内容 。
#点击 Add SSH key，可能会要求输入一次 GitHub 的登录密码确认 
#step 3:测试连接
#在终端输入以下命令：
ssh -T git@github.com
#若配置成功，会出现：
...You've successfully authenticated, but GitHub does not provide shell access.
