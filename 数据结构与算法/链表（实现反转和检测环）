if __name__ == "__main__":
    # 测试反转
    print("=== 测试反转 ===")
    llist = Linkedlist()
    for char in ['a', 'b', 'c']:
        llist.append(char)
    print("原始链表:")
    llist.display()          # a -> b -> c -> None
    llist.reverse()
    print("反转后:")
    llist.display()          # c -> b -> a -> None

    # 测试环检测（无环情况）
    print("\n=== 测试环检测（无环）===")
    print("当前链表是否有环:", llist.has_cycle())  # False

    # 构造一个带环的链表用于测试
    print("\n=== 测试环检测（有环）===")
    cycle_list = Linkedlist()
    node1 = Node(1)
    node2 = Node(2)
    node3 = Node(3)
    node4 = Node(4)
    cycle_list.head = node1
    node1.next = node2
    node2.next = node3
    node3.next = node4
    node4.next = node2   # 形成环：4 -> 2
    print("链表已人为构造一个环（4→2），检测结果:", cycle_list.has_cycle())  # True
